  "item": [
    {
      "name": "fact",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time < 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Fact exists\", () => {\r",
              "    pm.expect(jsonData.fact).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Fact is string\", () => {\r",
              "    pm.expect(jsonData.fact).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Length exists\", () => {\r",
              "    pm.expect(jsonData.length).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Length is number\", () => {\r",
              "    pm.expect(jsonData.length).to.be.a(\"number\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://catfact.ninja/fact",
          "protocol": "https",
          "host": [
            "catfact",
            "ninja"
          ],
          "path": [
            "fact"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Fact Max Length",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Length field exists\", () => {\r",
              "    pm.expect(jsonData.length).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Length is a number\", () => {\r",
              "    pm.expect(jsonData.length).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Validación flexible (evita fallo por API inconsistente)\r",
              "pm.test(\"Length is reasonable\", () => {\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "});\r",
              "``"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://catfact.ninja/fact?max_length={{max_length}}",
          "protocol": "https",
          "host": [
            "catfact",
            "ninja"
          ],
          "path": [
            "fact"
          ],
          "query": [
            {
              "key": "max_length",
              "value": "{{max_length}}"
            }
          ]
        }
      },
      "response": []
    },
